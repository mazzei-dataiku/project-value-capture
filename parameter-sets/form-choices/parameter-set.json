{
    "meta" : {
        "label": "Parameter set form-choices",
        "description": "",
        "icon": "fas fa-puzzle-piece"
    },
    "defaultDefinableInline": false,
    "defaultDefinableAtProjectLevel": false,
    "pluginParams": [
        {
            "name": "admin_client_profile",
            "label": "Admin Client Profile",
            "type": "STRING",
            "description": "Admin client profile name used by the runnable",
            "mandatory": true,
            "defaultValue": "admin"
        },
        {
            "name": "admin_api_token",
            "label": "Admin API Token",
            "type": "STRING",
            "description": "Admin API token identifier used by get_admin_dss_client",
            "mandatory": true,
            "defaultValue": "creation1"
        },
        {
            "name": "hub_project_name",
            "label": "Hub Project Name",
            "type": "STRING",
            "description": "Display name of the hub project (key is derived from this)",
            "mandatory": true,
            "defaultValue": "Project Value Hub"
        },
        {
            "name": "hub_project_owner",
            "label": "Hub Project Owner",
            "type": "STRING",
            "description": "DSS login that owns the hub project",
            "mandatory": true,
            "defaultValue": "admin"
        },
        {
            "name": "hub_project_description",
            "label": "Hub Project Description",
            "type": "STRING",
            "description": "Description used when creating the hub project",
            "mandatory": true,
            "defaultValue": "Central hub for project intake logging"
        },
        {
            "name": "hub_project_folder_id",
            "label": "Hub Project Folder Id",
            "type": "STRING",
            "description": "Optional project folder id for hub project creation",
            "mandatory": false,
            "defaultValue": ""
        },
        {
            "name": "bronze_dataset_name",
            "label": "Bronze Dataset Name",
            "type": "STRING",
            "description": "Dataset name in the hub project for intake audit logging",
            "mandatory": true,
            "defaultValue": "projects_intake_bronze"
        },
        {
            "name": "fc_proj_types",
            "label": "Project Types",
            "type": "STRINGS",
            "description": "Radio options for Project Type (POC is auto-added by the plugin and is not logged)",
            "mandatory": true,
            "defaultValue": [
                "Ad-Hoc",
                "Industrialization"
            ]
        },
        {
            "name": "fc_gbus",
            "label": "GBUs",
            "type": "STRINGS",
            "description": "Dropdown options for GBU",
            "mandatory": true,
            "defaultValue": [
                "Corp Functions",
                "Digital",
                "Gen Med",
                "Manufacturing and Supply",
                "R&D",
                "Specialty Care",
                "Vaccines"
            ]
        },
        {
            "name": "fc_business_users",
            "label": "Business Users",
            "type": "STRINGS",
            "description": "Multi-select options for Business Owner (include 'Other')",
            "mandatory": true,
            "defaultValue": [
                "Alice",
                "Bob",
                "Chloe",
                "Dylan",
                "Other"
            ]
        },
        {
            "name": "fc_technical_users",
            "label": "Technical Users",
            "type": "STRINGS",
            "description": "Multi-select options for Technical Owner (include 'Other')",
            "mandatory": true,
            "defaultValue": [
                "Erica",
                "Frank",
                "Gemma",
                "Hank",
                "Other"
            ]
        },
        {
            "name": "fc_value_drivers",
            "label": "Value Drivers",
            "type": "STRINGS",
            "description": "Dropdown options for Value Drivers",
            "mandatory": true,
            "defaultValue": [
                "Build New Capabilities",
                "Decrease Costs",
                "Decrease Time-to-Market",
                "Differentiate the Company",
                "Enhance Employee Skills",
                "Expand Market Share",
                "Foster a Culture of Innovation",
                "Improve Customer Satisfaction",
                "Improve Employee Satisfaction",
                "Improve Productivity / Efficiency",
                "Improve Profit Margin",
                "Improve Regulatory Compliance",
                "Increase Customer Retention",
                "Increase Revenue",
                "Mitigate Operational Risk",
                "Reduce Error Rates",
                "Reduce Security Incidents"
            ]
        },
        {
            "name": "fc_non_fin_impact_levels",
            "label": "Non-Financial Impact Levels",
            "type": "STRINGS",
            "description": "Dropdown options for non-financial impact sizing",
            "mandatory": true,
            "defaultValue": [
                "Low",
                "Moderate",
                "Significant",
                "Substantial",
                "Unknown"
            ]
        },
        {
            "name": "financial_value_drivers",
            "label": "Financial Value Drivers",
            "type": "STRINGS",
            "description": "Subset of Value Drivers that should use numeric USD input",
            "mandatory": true,
            "defaultValue": [
                "Improve Profit Margin",
                "Increase Revenue",
                "Decrease Costs"
            ]
        }
    ],
    "params": []
}
